library(tidyverse)
library(gggenes)
library(patchwork)
install.packages("gggenes")
install.packages("patchwork")
library(tidyverse)
library(gggenes)
library(patchwork)
vecindario_ddl  <- read_csv("vecindario_ddl.csv",  show_col_types = FALSE)
vecindario_mreB <- read_csv("vecindario_mreB.csv", show_col_types = FALSE)
vecindario_rodZ <- read_csv("vecindario_rodZ.csv", show_col_types = FALSE)
orden_genomas <- unique(c(
vecindario_ddl$genome_id,
vecindario_mreB$genome_id,
vecindario_rodZ$genome_id
))
genes <- c("murG", "murC", "murB", "ddl", "ftsQ", "ftsA",
"ftsZ", "lpxC", "mreB", "mreC", "mreD", "mrdA", "rodA", "mltB", "rlpA", "rodZ")
paleta <- setNames(
c("#4C7C6A", "#8C7263", "#C9A6D6", "#000000", "#6EC1D9", "#D9534F",
"#8FBF6E", "#5B4B8A", "#000000", "#7A9B57", "#D9534F", "#4A90D9",
"#6E7B7C", "#C77DBA", "#B0A0C9", "#D9534F"),
genes
)
preparar_panel <- function(vecindario, titulo_panel) {
vecindario %>%
mutate(
genome_id = factor(genome_id, levels = orden_genomas),
# el color se basa en el nombre del gen (sin el sufijo 1/2 de las duplicaciones)
color_gen = if_else(!is.na(gen_focal), gen_focal, "otro"),
titulo = titulo_panel
)
}
datos_ddl  <- preparar_panel(vecindario_ddl,  "lack of ftsQ and ftsA")
datos_mreB <- preparar_panel(vecindario_mreB, "duplication of elongasome genes")
datos_rodZ <- preparar_panel(vecindario_rodZ, "rodZ neighborhood")
graficar_panel <- function(datos, mostrar_eje_y) {
ggplot(datos, aes(
xmin = start_rel, xmax = end_rel, y = genome_id,
fill = color_gen, forward = strand == "+", label = etiqueta
)) +
geom_gene_arrow(color = "grey40", linewidth = 0.1) +
geom_gene_label(align = "centre", min.size = 5) +
scale_fill_manual(
values = c(paleta, "otro" = "grey80"),
na.value = "grey80",
guide = "none"
) +
scale_y_discrete(limits = orden_genomas, drop = FALSE) +
theme_genes() +
theme(
axis.text.y = if (mostrar_eje_y) element_text(size = 7) else element_blank(),
axis.title.y = element_blank(),
strip.text = element_text(face = "bold")
) +
facet_wrap(~titulo)
}
p_ddl  <- graficar_panel(datos_ddl,  mostrar_eje_y = TRUE)
p_mreB <- graficar_panel(datos_mreB, mostrar_eje_y = FALSE)
p_rodZ <- graficar_panel(datos_rodZ, mostrar_eje_y = FALSE)
figura_final <- p_ddl + p_mreB + p_rodZ +
plot_layout(widths = c(1.3, 1.5, 0.8))
ggsave("sintenia_final.png", plot = figura_final, width = 18, height = 10, dpi = 300)
ggsave("sintenia_final.pdf", plot = figura_final, width = 18, height = 10, dpi = 300)
cat("listo: sintenia_final.png / .pdf\n")
