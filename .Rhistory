) %>%
group_by(gen_focal) %>%
arrange(start_rel) %>%
mutate(
n_grupo = n(),
etiqueta = case_when(
is.na(gen_focal) ~ NA_character_,
n_grupo > 1 ~ paste0(gen_focal, row_number()),
TRUE ~ gen_focal
)
) %>%
select(-n_grupo) %>%
ungroup()
