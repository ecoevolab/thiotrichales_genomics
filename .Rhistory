# Directorio donde estan las subcarpetas por gen (de los alineamientos/hmmer)
base_dir <- "/Users/monicareyes/Desktop/aligments"
# Carpeta donde estan los GFFs individuales ya limpios
gff_dir <- "/Users/monicareyes/Desktop/gff_procesados"
# Lista de los 16 genes focales (deben coincidir con el nombre de carpeta y de archivo)
genes <- c("murG", "murC", "murB", "ddl", "ftsQ", "ftsA",
"ftsZ", "lpxC", "mreB", "mreC", "mreD", "mrdA", "rodA", "mltB", "rlpA", "rodZ")
# Lista de los 16 genes focales (deben coincidir con el nombre de carpeta y de archivo)
genes <- c("murG", "murC", "murB", "ddl", "ftsQ", "ftsA",
"ftsZ", "lpxC", "mreB", "mreC", "mreD", "mrdA", "rodA", "mltB", "rlpA", "rodZ")
leer_filtrado <- function(gen) {
archivo <- file.path(base_dir, gen, paste0("salida_", gen, "_filtrado.tsv"))
read_tsv(archivo, show_col_types = FALSE,
col_types = cols(genome_id = col_character())) %>%
mutate(
gen = gen,
# locus_tag = lo que sigue despues del genome_id y el guion bajo
locus_tag = str_remove(genome_locustag, paste0("^", genome_id, "_"))
) %>%
select(gen, genome_id, locus_tag, evalue)
}
hits_focales <- map_dfr(genes, leer_filtrado)
leer_gff <- function(archivo_gff) {
genome_id <- basename(archivo_gff) %>% str_remove("_limpio\\.gff$")
read_tsv(archivo_gff, show_col_types = FALSE, col_names = FALSE,
col_types = cols(.default = "c")) %>%
rename(contig = X1, source = X2, type = X3, start = X4,
end = X5, score = X6, strand = X7, phase = X8, attributes = X9) %>%
filter(type == "CDS") %>%
mutate(
genome_id = genome_id,
start = as.integer(start),
end = as.integer(end),
locus_tag = str_extract(attributes, "locus_tag=[^;]+") %>% str_remove("locus_tag=")
) %>%
select(genome_id, contig, start, end, strand, locus_tag)
}
archivos_gff <- list.files(gff_dir, pattern = "_limpio\\.gff$", full.names = TRUE)
todos_los_cds <- map_dfr(archivos_gff, leer_gff)
coordenadas_focales <- hits_focales %>%
left_join(todos_los_cds, by = c("genome_id", "locus_tag")) %>%
mutate(coordenada_encontrada = !is.na(contig))
sin_coordenadas <- coordenadas_focales %>% filter(!coordenada_encontrada)
if (nrow(sin_coordenadas) > 0) {
cat("ATENCION -- hits sin coordenadas encontradas en el gff:\n")
print(sin_coordenadas)
} else {
cat("todos los hits confirmados tienen coordenadas, ok\n")
}
write_csv(coordenadas_focales, "coordenadas_genes_focales.csv")
print(sin_coordenadas)
if (nrow(sin_coordenadas) > 0) {
cat("ATENCION -- hits sin coordenadas encontradas en el gff:\n")
print(sin_coordenadas)
} else {
cat("todos los hits confirmados tienen coordenadas, ok\n")
}
write_csv(coordenadas_focales, "coordenadas_genes_focales.csv")
cat("listo: coordenadas_genes_focales.csv generado\n")
View(coordenadas_focales)
print(sin_coordenadas)
print(sin_coordenadas)
sin_coordenadas <- coordenadas_focales %>% filter(!coordenada_encontrada)
if (nrow(sin_coordenadas) > 0) {
cat("ATENCION -- hits sin coordenadas encontradas en el gff:\n")
print(sin_coordenadas)
} else {
cat("todos los hits confirmados tienen coordenadas, ok\n")
}
write_csv(coordenadas_focales, "coordenadas_genes_focales.csv")
cat("listo: coordenadas_genes_focales.csv generado\n")
extraer_vecindario_gen <- function(gen_ancla, ventana) {
hits_ancla <- coordenadas_focales %>%
filter(gen == gen_ancla, coordenada_encontrada)
genomas_con_ancla <- unique(hits_ancla$genome_id)
map_dfr(genomas_con_ancla, function(gid) {
hits_este_genoma <- hits_ancla %>% filter(genome_id == gid)
# si por algun motivo las copias del ancla cayeran en contigs distintos,
# nos quedamos con el contig que tenga mas copias (caso raro, se reporta)
contig_usar <- hits_este_genoma %>%
count(contig, sort = TRUE) %>%
slice(1) %>%
pull(contig)
if (n_distinct(hits_este_genoma$contig) > 1) {
cat("aviso:", gid, "-", gen_ancla, "tiene copias en mas de un contig, se uso el contig con mas copias\n")
}
hits_este_genoma <- hits_este_genoma %>% filter(contig == contig_usar)
# todos los CDS de ese genoma, en ese contig, ya ordenados por posicion
cds_contig <- todos_los_cds %>%
filter(genome_id == gid, contig == contig_usar) %>%
arrange(start)
# posicion (indice) de cada copia del ancla dentro de la lista ordenada
indices_ancla <- which(cds_contig$locus_tag %in% hits_este_genoma$locus_tag)
if (length(indices_ancla) == 0) return(NULL)
# centro de la ventana: punto medio entre la primera y ultima copia del ancla
centro <- mean(indices_ancla)
ini <- max(1, floor(centro - ventana))
fin <- min(nrow(cds_contig), ceiling(centro + ventana))
vecindario <- cds_contig[ini:fin, ]
# referencia para recentrar: inicio de la copia MAS a la izquierda del ancla
referencia <- min(cds_contig$start[indices_ancla])
vecindario <- vecindario %>%
mutate(
start_rel = start - referencia,
end_rel = end - referencia
)
# strand del ancla principal (la primera copia), para decidir si se voltea
strand_ancla <- cds_contig$strand[indices_ancla[1]]
if (strand_ancla == "-") {
max_end <- max(vecindario$end_rel)
vecindario <- vecindario %>%
mutate(
nuevo_start = max_end - end_rel,
nuevo_end   = max_end - start_rel,
strand      = if_else(strand == "+", "-", "+")
) %>%
mutate(start_rel = nuevo_start, end_rel = nuevo_end) %>%
select(-nuevo_start, -nuevo_end)
}
# marcar cuales genes de la ventana son focales (de los 16), y cual gen son
vecindario <- vecindario %>%
left_join(
hits_focales %>% select(genome_id, locus_tag, gen_focal = gen),
by = c("genome_id", "locus_tag")
) %>%
mutate(panel = gen_ancla) %>%
group_by(gen_focal) %>%
arrange(start_rel) %>%
mutate(
etiqueta = if_else(
!is.na(gen_focal),
if_else(n() > 1, paste0(gen_focal, row_number()), gen_focal),
NA_character_
)
) %>%
ungroup()
vecindario
})
}
vecindario_ddl  <- extraer_vecindario_gen("ddl", ventana = 5)
vecindario_mreB <- extraer_vecindario_gen("mreB", ventana = 10)
vecindario_rodZ <- extraer_vecindario_gen("rodZ", ventana = 6)
write_csv(vecindario_ddl,  "vecindario_ddl.csv")
write_csv(vecindario_mreB, "vecindario_mreB.csv")
write_csv(vecindario_rodZ, "vecindario_rodZ.csv")
